{
  "buildCommand": "cd projects/personal-site-apple && npm install && npm run build",
  "outputDirectory": "projects/personal-site-apple/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/$1" }
  ],
  "functions": {
    "api/chat.js": {
      "maxDuration": 30
    }
  }
}

